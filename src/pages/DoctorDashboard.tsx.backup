import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { Users, Activity, Edit, Trash2, LogOut, UserPlus } from 'lucide-react';
import { useAuth } from '../contexts/AuthContext';
import { supabase, Patient } from '../lib/supabase';
import { Button } from '../components/Button';
import { Modal } from '../components/Modal';
import { PatientForm } from '../components/PatientForm';
import { DrugInteractionChecker } from '../components/DrugInteractionChecker';
import { Toast } from '../components/Toast';

export function DoctorDashboard() {
  const { user, logout } = useAuth();
  const navigate = useNavigate();
  const [patients, setPatients] = useState<Patient[]>([]);
  const [selectedPatient, setSelectedPatient] = useState<Patient | null>(null);
  const [showPatientModal, setShowPatientModal] = useState(false);
  const [editingPatient, setEditingPatient] = useState<Patient | null>(null);
  const [activeTab, setActiveTab] = useState<'patients' | 'checker' | 'history'>('patients');
  const [searchTerm, setSearchTerm] = useState('');
  const [toast, setToast] = useState<{ message: string; type: 'success' | 'error' } | null>(null);

  useEffect(() => {
    if (!user || user.role !== 'doctor') {
      navigate('/');
    } else {
      loadPatients();
    }
  }, [user, navigate]);

  const loadPatients = async () => {
    if (!user) return;

    const { data, error } = await supabase
      .from('patients')
      .select('*')
      .eq('doctor_id', user.id)
      .order('created_at', { ascending: false });

    if (data) {
      setPatients(data);
    }
  };

  const handleSavePatient = async (patientData: Omit<Patient, 'id' | 'doctor_id' | 'created_at'>) => {
    if (!user) return;

    try {
      if (editingPatient) {
        const { error } = await supabase
          .from('patients')
          .update(patientData)
          .eq('id', editingPatient.id);

        if (error) throw error;
        setToast({ message: 'Patient mis à jour avec succès', type: 'success' });
      } else {
        const { error } = await supabase
          .from('patients')
          .insert({ ...patientData, doctor_id: user.id });

        if (error) throw error;
        setToast({ message: 'Patient ajouté avec succès', type: 'success' });
      }

      setShowPatientModal(false);
      setEditingPatient(null);
      loadPatients();
    } catch (error) {
      setToast({ message: 'Erreur lors de l\'enregistrement', type: 'error' });
    }
  };

  const handleDeletePatient = async (patientId: string) => {
    if (!confirm('Êtes-vous sûr de vouloir supprimer ce patient?')) return;

    try {
      const { error } = await supabase
        .from('patients')
        .delete()
        .eq('id', patientId);

      if (error) throw error;
      setToast({ message: 'Patient supprimé avec succès', type: 'success' });
      loadPatients();
      if (selectedPatient?.id === patientId) {
        setSelectedPatient(null);
      }
    } catch (error) {
      setToast({ message: 'Erreur lors de la suppression', type: 'error' });
    }
  };

  const handleLogout = async () => {
    await logout();
    navigate('/');
  };

  const filteredPatients = patients.filter(patient =>
    patient.nom_complet.toLowerCase().includes(searchTerm.toLowerCase())
  );

  return (
    <div className="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">
      {toast && (
        <Toast
          message={toast.message}
          type={toast.type}
          onClose={() => setToast(null)}
        />
      )}

      <header className="glass-effect border-b border-gray-200 sticky top-0 z-40">
        <div className="max-w-7xl mx-auto px-6 py-4">
          <div className="flex items-center justify-between">
            <div className="flex items-center space-x-4">
              <div className="p-2 bg-secondary-100 rounded-xl">
                <Activity className="w-6 h-6 text-secondary-600" />
              </div>
              <div>
                <h1 className="text-2xl font-bold text-gray-900">Corvax Health</h1>
                <p className="text-sm text-gray-600">{user?.doctor_name || 'Médecin'}</p>
              </div>
            </div>
            <Button variant="ghost" size="sm" onClick={handleLogout}>
              <LogOut className="w-4 h-4 mr-2" />
              Déconnexion
            </Button>
          </div>
        </div>
      </header>

      <div className="max-w-7xl mx-auto px-6 py-8">
        <div className="glass-effect rounded-2xl border border-gray-200 overflow-hidden">
          <div className="border-b border-gray-200">
            <div className="flex">
              <button
                onClick={() => setActiveTab('patients')}
                className={`flex-1 px-6 py-4 text-sm font-medium transition-colors ${
                  activeTab === 'patients'
                    ? 'text-primary-600 border-b-2 border-primary-600 bg-primary-50'
                    : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                }`}
              >
                <Users className="w-5 h-5 inline mr-2" />
                Gestion des Patients
              </button>
              <button
                onClick={() => setActiveTab('checker')}
                className={`flex-1 px-6 py-4 text-sm font-medium transition-colors ${
                  activeTab === 'checker'
                    ? 'text-primary-600 border-b-2 border-primary-600 bg-primary-50'
                    : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                }`}
              >
                <Activity className="w-5 h-5 inline mr-2" />
                Vérification d'Interactions
              </button>
            </div>
          </div>

          <div className="p-6">
            {activeTab === 'patients' && (
              <div className="space-y-6">
                <div className="flex items-center justify-between">
                  <div className="flex-1 max-w-md">
                    <input
                      type="text"
                      placeholder="Rechercher un patient..."
                      value={searchTerm}
                      onChange={(e) => setSearchTerm(e.target.value)}
                      className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none"
                    />
                  </div>
                  <Button
                    onClick={() => {
                      setEditingPatient(null);
                      setShowPatientModal(true);
                    }}
                    variant="primary"
                  >
                    <UserPlus className="w-4 h-4 mr-2" />
                    Ajouter un Patient
                  </Button>
                </div>

                <div className="overflow-x-auto">
                  <table className="w-full">
                    <thead>
                      <tr className="border-b-2 border-gray-200">
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Nom</th>
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Âge</th>
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Sexe</th>
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Maladies</th>
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Allergies</th>
                        <th className="px-4 py-3 text-left text-sm font-semibold text-gray-700">Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      {filteredPatients.map((patient) => (
                        <tr
                          key={patient.id}
                          className={`border-b border-gray-100 hover:bg-gray-50 transition-colors cursor-pointer ${
                            selectedPatient?.id === patient.id ? 'bg-primary-50' : ''
                          }`}
                          onClick={() => setSelectedPatient(patient)}
                        >
                          <td className="px-4 py-4 text-sm font-medium text-gray-900">{patient.nom_complet}</td>
                          <td className="px-4 py-4 text-sm text-gray-700">{patient.age}</td>
                          <td className="px-4 py-4 text-sm text-gray-700">{patient.sexe}</td>
                          <td className="px-4 py-4 text-sm text-gray-700">
                            {patient.maladies_chroniques.length > 0 ? (
                              <div className="flex flex-wrap gap-1">
                                {patient.maladies_chroniques.slice(0, 2).map((maladie, idx) => (
                                  <span key={idx} className="px-2 py-1 bg-caution-100 text-caution-700 rounded text-xs">
                                    {maladie}
                                  </span>
                                ))}
                                {patient.maladies_chroniques.length > 2 && (
                                  <span className="px-2 py-1 bg-gray-100 text-gray-700 rounded text-xs">
                                    +{patient.maladies_chroniques.length - 2}
                                  </span>
                                )}
                              </div>
                            ) : (
                              <span className="text-gray-400">Aucune</span>
                            )}
                          </td>
                          <td className="px-4 py-4 text-sm text-gray-700">
                            {patient.allergies.length > 0 ? (
                              <div className="flex flex-wrap gap-1">
                                {patient.allergies.slice(0, 2).map((allergie, idx) => (
                                  <span key={idx} className="px-2 py-1 bg-danger-100 text-danger-700 rounded text-xs">
                                    {allergie}
                                  </span>
                                ))}
                                {patient.allergies.length > 2 && (
                                  <span className="px-2 py-1 bg-gray-100 text-gray-700 rounded text-xs">
                                    +{patient.allergies.length - 2}
                                  </span>
                                )}
                              </div>
                            ) : (
                              <span className="text-gray-400">Aucune</span>
                            )}
                          </td>
                          <td className="px-4 py-4 text-sm">
                            <div className="flex space-x-2" onClick={(e) => e.stopPropagation()}>
                              <button
                                onClick={() => {
                                  setEditingPatient(patient);
                                  setShowPatientModal(true);
                                }}
                                className="p-2 text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
                              >
                                <Edit className="w-4 h-4" />
                              </button>
                              <button
                                onClick={() => handleDeletePatient(patient.id)}
                                className="p-2 text-danger-600 hover:bg-danger-50 rounded-lg transition-colors"
                              >
                                <Trash2 className="w-4 h-4" />
                              </button>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                  {filteredPatients.length === 0 && (
                    <div className="text-center py-12">
                      <Users className="w-12 h-12 text-gray-400 mx-auto mb-3" />
                      <p className="text-gray-600">Aucun patient trouvé</p>
                    </div>
                  )}
                </div>
              </div>
            )}

            {activeTab === 'checker' && (
              <div>
                {selectedPatient && (
                  <div className="mb-4 p-4 glass-effect rounded-lg border border-primary-200">
                    <p className="text-sm text-gray-600">
                      Patient sélectionné: <span className="font-semibold text-gray-900">{selectedPatient.nom_complet}</span>
                    </p>
                    <button
                      onClick={() => setSelectedPatient(null)}
                      className="text-xs text-primary-600 hover:text-primary-700 mt-1"
                    >
                      Désélectionner
                    </button>
                  </div>
                )}
                <DrugInteractionChecker patient={selectedPatient} doctorId={user?.id || ''} />
              </div>
            )}
          </div>
        </div>
      </div>

      <Modal
        isOpen={showPatientModal}
        onClose={() => {
          setShowPatientModal(false);
          setEditingPatient(null);
        }}
        title={editingPatient ? 'Modifier le Patient' : 'Ajouter un Patient'}
        size="lg"
      >
        <PatientForm
          patient={editingPatient}
          onSave={handleSavePatient}
          onCancel={() => {
            setShowPatientModal(false);
            setEditingPatient(null);
          }}
        />
      </Modal>
    </div>
  );
}
