root = true

[*]
charset             = utf-8
end_of_line         = lf
indent_style        = space
indent_size         = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{png,jpg,jpeg,gif,ico,woff,woff2,ttf,eot,pdf,zip}]
# binary files — no text transforms
